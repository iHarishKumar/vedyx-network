# =============================================================================
# VEDYX PROTOCOL - ENVIRONMENT VARIABLES (EXAMPLE TEMPLATE)
# =============================================================================
# Copy this file to .env and fill in your actual values
# This file is tracked in git as a reference template

# -----------------------------------------------------------------------------
# WEB3 WALLET CONNECTION (Required)
# -----------------------------------------------------------------------------
# WalletConnect Project ID - Required for wallet connection via RainbowKit
# Get your project ID from: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# -----------------------------------------------------------------------------
# API ENDPOINTS (Optional)
# -----------------------------------------------------------------------------
# Backend API URL - For fetching alerts, analytics, and contract data
# NEXT_PUBLIC_API_URL=http://localhost:8000/api

# WebSocket URL - For real-time alert notifications
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# -----------------------------------------------------------------------------
# SMART CONTRACT ADDRESSES (Optional - add when contracts are deployed)
# -----------------------------------------------------------------------------
# Large Transfer Detector Contract Address
# NEXT_PUBLIC_LARGE_TRANSFER_DETECTOR_ADDRESS=0x...

# Price Manipulation Detector Contract Address
# NEXT_PUBLIC_PRICE_MANIPULATION_DETECTOR_ADDRESS=0x...

# Reentrancy Detector Contract Address
# NEXT_PUBLIC_REENTRANCY_DETECTOR_ADDRESS=0x...
